# Environment Variables
# Copy this to backend/.env for local development.
# Add the same keys in Render for production.

# Database
# Production should use PostgreSQL (Render Postgres or Supabase).
DATABASE_URL=postgresql://user:password@host:5432/smartgate
# DB_URL also works, but DATABASE_URL is clearer for managed hosting.
# DB_URL=postgresql://user:password@host:5432/smartgate

# Security
SECRET_KEY=change_me_to_random_32_plus_character_secret_key_here
JWT_SECRET=change_me_to_another_random_jwt_secret_key_here
JWT_ALG=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=720
QR_TTL_MINUTES=15

# Registration Flow
SELF_REGISTRATION_ENABLED=false
ACCOUNT_REQUESTS_ENABLED=true
SMARTGATE_SEED_MODE=never

# Feature Toggles
FACE_AUTH_ENABLED=true
FACE_AUTH_BACKEND=opencv
NOTIFICATIONS_ENABLED=false
GEOFENCE_ENABLED=true

# Firebase Push Notifications (optional)
# Paste the entire Firebase service-account JSON as one line.
FIREBASE_CREDENTIALS_JSON=

# Twilio SMS (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
